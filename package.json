{
  "name": "agentify-cli",
  "version": "0.2.1",
  "description": "Agent Interface Compiler — One command. Every agent speaks your product.",
  "type": "module",
  "bin": {
    "agentify": "./dist/cli.js",
    "agentify-cli": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agent",
    "openapi",
    "ai",
    "skills",
    "agent-native",
    "compiler",
    "a2a",
    "claude",
    "cursor",
    "copilot",
    "llms-txt",
    "agents-md"
  ],
  "author": "Agentify Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/koriyoshi2041/agentify.git"
  },
  "homepage": "https://github.com/koriyoshi2041/agentify#readme",
  "bugs": {
    "url": "https://github.com/koriyoshi2041/agentify/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "handlebars": "^4.7.8",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
